---
interface Props {
  affiliateUrl?: string;
}

const { affiliateUrl = "https://www.gohighlevel.com/?fp_ref=saascass" } = Astro.props;
---

<aside class="hidden lg:block">
  <div class="fixed left-8 top-32 w-64 max-h-[calc(100vh-8rem)] overflow-y-auto">
    <!-- Author Card -->
    <div class="bg-gradient-to-br from-violet-50 to-blue-50 rounded-2xl border border-violet-200 p-6 sticky top-32">
      <!-- Avatar -->
      <div class="flex justify-center mb-4">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-violet-400 to-blue-500 flex items-center justify-center text-white font-bold text-xl">
          C
        </div>
      </div>

      <!-- Author Info -->
      <h3 class="text-lg font-bold text-gray-900 text-center mb-2">Cass</h3>
      <p class="text-xs text-gray-600 text-center mb-4">
        Web designer & SaaS reviewer exploring tools that actually work.
      </p>

      <!-- Social Proof -->
      <div class="text-center mb-5 py-4 border-t border-b border-violet-200">
        <p class="text-xs text-gray-500">
          <span class="font-bold text-violet-600">10+</span> tools reviewed
        </p>
      </div>

      <!-- CTA -->
      <a 
        href={affiliateUrl}
        target="_blank" 
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full bg-gradient-to-r from-violet-600 to-blue-600 text-white font-bold py-3 px-4 rounded-full hover:shadow-lg transition-all duration-200 mb-3"
      >
        <!-- GHL Logo/Icon -->
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
        </svg>
        Start Free Trial
      </a>

      <p class="text-xs text-gray-400 text-center">
        No credit card required
      </p>
    </div>
  </div>
</aside>

<style>
  aside > div {
    scroll-behavior: smooth;
    position: fixed;
    top: 8rem;
    left: 2rem;
    width: 16rem;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
  }

  @media (max-width: 1024px) {
    aside {
      display: none !important;
    }
  }
</style>
