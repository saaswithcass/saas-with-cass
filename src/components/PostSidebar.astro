---
interface Props {
  affiliateUrl?: string;
}

const { affiliateUrl = "https://www.gohighlevel.com/?fp_ref=saascass" } = Astro.props;
---

<aside class="hidden lg:block">
  <div class="fixed left-8 top-32 w-64 max-h-[calc(100vh-8rem)] overflow-y-auto">
    <!-- Author Card -->
    <div class="bg-gradient-to-br from-violet-50 to-blue-50 rounded-2xl border border-violet-200 p-6 sticky top-32">
      <!-- Avatar -->
      <div class="flex justify-center mb-4">
        <img src="/images/cass-profile.jpg" alt="Cass" class="w-20 h-20 rounded-full object-cover border-4 border-white shadow-lg" />
      </div>

      <!-- Author Info -->
      <h3 class="text-lg font-bold text-gray-900 text-center mb-2">Cass</h3>
      <p class="text-xs text-gray-600 text-center mb-4">
        Web designer & SaaS reviewer exploring tools that actually work.
      </p>

      <!-- Social Proof -->
      <div class="text-center mb-5 py-4 border-t border-b border-violet-200">
        <p class="text-xs text-gray-500">
          <span class="font-bold text-violet-600">10+</span> tools reviewed
        </p>
      </div>

      <!-- CTA -->
      <a 
        href={affiliateUrl}
        target="_blank" 
        rel="noopener noreferrer"
        class="block w-full bg-gradient-to-r from-violet-600 to-blue-600 text-white font-bold py-3 px-4 rounded-full hover:shadow-lg transition-all duration-200 mb-3 text-center text-sm"
      >
        Free Trial of GoHighLevel
      </a>
    </div>
  </div>
</aside>

<style>
  aside > div {
    scroll-behavior: smooth;
    position: fixed;
    top: 8rem;
    right: 2rem;
    width: 16rem;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
  }

  @media (max-width: 1024px) {
    aside {
      display: none !important;
    }
  }
</style>
