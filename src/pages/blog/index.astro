---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))].sort();
---

<Layout title="Blog" description="All posts — honest takes on SaaS, tools, and building a business online.">
  <div class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">All Posts</h1>
    <p class="text-gray-400 text-sm mb-10">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>

    {categories.length > 1 && (
      <div class="flex flex-wrap gap-2 mb-10">
        {categories.map(cat => (
          <span class="text-xs font-medium text-gray-500 bg-gray-100 px-3 py-1.5 rounded-full">{cat}</span>
        ))}
      </div>
    )}

    <div>
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          slug={post.id}
          description={post.data.description}
          date={post.data.date}
          category={post.data.category}
          tags={post.data.tags}
        />
      ))}
    </div>
  </div>
</Layout>
